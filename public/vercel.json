{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/auth", "dest": "/api/auth.js" },
    { "src": "/api/callback", "dest": "/api/callback.js" },
    { "src": "/api/athlete", "dest": "/api/server.js" },
    { "src": "/api/activities", "dest": "/api/server.js" },
    { "src": "/api/stats", "dest": "/api/server.js" },
    { "src": "/dashboard", "dest": "/api/dashboard.js" },
    { "src": "/", "dest": "/api/index.js" }
  ]
}