{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/callback",
      "dest": "/api/callback.js"
    },
    {
      "src": "/dashboard",
      "dest": "/api/server.js"
    },
    {
      "src": "/",
      "dest": "/api/server.js"
    }
  ]
}